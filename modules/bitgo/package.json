{
  "name": "bitgo",
  "version": "52.3.1",
  "description": "BitGo JavaScript SDK",
  "main": "./dist/src/index.js",
  "types": "./dist/types/src/index.d.ts",
  "keywords": [
    "bitgo",
    "bitcoin",
    "bitgojs"
