# BitGo API Access Token
# Get your token from: https://app.bitgo-test.com (test) or https://app.bitgo.com (production)
TESTNET_ACCESS_TOKEN=your_testnet_access_token_here

# Enterprise ID for wallet creation
# Find this in your BitGo dashboard under Settings > Enterprise
ENTERPRISE_ID=your_enterprise_id_here

# Passphrase for encrypting wallet user keys
# Use a strong, unique passphrase and store it securely!
WALLET_PASSPHRASE=your_secure_passphrase_here
